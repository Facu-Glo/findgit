#!/usr/bin/env bash
CONFIG="${XDG_CONFIG_HOME:-$HOME/.config}/findgit/config.json"

load_config() {
    local config_file="$1"

    if ! search_paths=($(jq -r '.search_paths[]' "$config_file" 2>/dev/null)); then
        echo "Error: Could not read search paths from the configuration file" >&2
        return 1
    fi
    if ! ignore_paths=($(jq -r '.ignore_paths[]' "$config_file" 2>/dev/null | sed 's/^/-E /')); then
        ignore_paths=()
    fi
    if [[ ${#search_paths[@]} -eq 0 ]]; then
        echo "Error: No search paths configured" >&2
        return 1
    fi
    return 0
}

find_git_repos() {
    local -n paths=$1
    local -n ignores=$2
    
    fd -t d -H --max-depth 6 '^\.git$' "${paths[@]}" "${ignores[@]}" --exec dirname {} \; 2>/dev/null | sort -u
}

get_repo_status() {
    local repo="$1"
    local toplevel git_timestamp status_code color
    
    toplevel=$(git -C "$repo" rev-parse --show-toplevel 2>/dev/null) || return 1
    [[ "$toplevel" != "$repo" ]] && return 1
    
    if ! git -C "$repo" rev-parse --verify HEAD >/dev/null 2>&1; then
        git_timestamp="0"
        if has_untracked_files "$repo"; then
            status_code="1"
            color="\033[31m"  # Rojo
        else
            status_code="2"
            color="\033[37m"  # Gris
        fi
    else
        git_timestamp=$(git -C "$repo" --no-pager log -1 --format="%ct" 2>/dev/null || echo "0")
        
        if is_repo_clean "$repo"; then
            status_code="2"
            color="\033[37m"  # Gris
        else
            status_code="1"
            color="\033[31m"  # Rojo
        fi
    fi
    
    echo -e "${status_code}\t${git_timestamp}\t${repo}\t${color}${repo}\033[0m"
}

has_untracked_files() {
    local repo="$1"
    [[ -n $(git -C "$repo" ls-files --others --exclude-standard 2>/dev/null) ]]
}

is_repo_clean() {
    local repo="$1"
    
    git -C "$repo" diff-index --quiet HEAD -- 2>/dev/null && \
    git -C "$repo" diff-files --quiet 2>/dev/null && \
    ! has_untracked_files "$repo"
}

process_repos() {
    xargs -I {} -P "$(nproc)" bash -c 'get_repo_status "$@"' _ {}
}

get_fzf_preview_command() {
    cat <<'EOF'
echo -e '\033[32m󰊢 Git Status:\033[0m'
status_output=$(git -C {2} -c color.status=always status --short 2>/dev/null)
if [[ -n "$status_output" ]]; then
    echo "$status_output"
else
    echo 'No hay modificaciones'
fi
echo -e '\n Contenido:'
if command -v eza &> /dev/null; then
    eza --color=always -al --icons {2} 2>/dev/null || ls -la {1}
else
    ls -la {2}
fi
EOF
}

format_and_select() {
    sort -k1,1n -k2,2nr | \
    cut -f3,4 | \
    cat -n | \
    fzf --ansi \
        --with-nth=1,3 \
        --preview "$(get_fzf_preview_command)" | \
    awk '{print $2}'
}

_findgit() {
    local dir
    
    load_config "$CONFIG" || return 1
    
    dir=$(
        find_git_repos search_paths ignore_paths | \
        process_repos | \
        format_and_select
    )
    
    [[ -n $dir ]] && echo "$dir"
}

export -f get_repo_status
export -f has_untracked_files
export -f is_repo_clean

_findgit
